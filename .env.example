# Configurações do Docker
COMPOSE_PROJECT_NAME=meu-cms
COMPOSE_FILE=docker-compose.yml

# Controle de ambiente (development ou production)
APP_ENV=development

# Portas dos serviços
WEB_PORT=
DB_PORT=

# Versões das imagens
PHP_VERSION=
NODE_VERSION=

# Banco de dados
DB_ROOT_PASSWORD=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Condição do volume (apenas para desenvolvimento)
VOLUME_CONDITION=