# Configurações do Docker
COMPOSE_PROJECT_NAME=meu-cms
COMPOSE_FILE=docker-compose.yml

# Controle de ambiente (development ou production)
APP_ENV=development

# Portas dos serviços
WEB_PORT=8080
DB_PORT=3307

# Versões das imagens
PHP_VERSION=8.2
NODE_VERSION=18

# Banco de dados
DB_ROOT_PASSWORD=root
DB_DATABASE=sites
DB_USERNAME=usersite
DB_PASSWORD=usersite

# Condição do volume (apenas para desenvolvimento)
VOLUME_CONDITION=consistent